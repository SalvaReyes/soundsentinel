SOUNDSENTINEL_REPEATED_PEAK_WINDOW_SECONDS=2
SOUNDSENTINEL_REPEATED_PEAK_MIN_COUNT=3
SOUNDSENTINEL_ALERT_COOLDOWN_SECONDS=60
SOUNDSENTINEL_TELEGRAM_API_BASE_URL=https://api.telegram.org
SOUNDSENTINEL_NOTIFICATION_REQUEST_TIMEOUT_SECONDS=10

SOUNDSENTINEL_POSTGRES_USER=soundsentinel
SOUNDSENTINEL_POSTGRES_PASSWORD=soundsentinel
SOUNDSENTINEL_POSTGRES_DB=soundsentinel
