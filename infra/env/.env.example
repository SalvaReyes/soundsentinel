SOUNDSENTINEL_APP_NAME=SoundSentinel
SOUNDSENTINEL_ENVIRONMENT=development
SOUNDSENTINEL_DEBUG=true
SOUNDSENTINEL_APP_VERSION=0.1.0
SOUNDSENTINEL_MAX_AUDIO_UPLOAD_BYTES=2000000
